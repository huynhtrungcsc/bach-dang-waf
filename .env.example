## ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/waf_console?schema=public"

DB_NAME=waf_console
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

## ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

## ── JWT secrets (generate with: openssl rand -hex 48) ──────────────────────
JWT_ACCESS_SECRET="replace-with-random-secret"
JWT_REFRESH_SECRET="replace-with-random-secret"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

## ── Session ─────────────────────────────────────────────────────────────────
SESSION_SECRET="replace-with-random-secret"

## ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# The nginx frontend proxy rewrites Origin headers, so only localhost origins
# are typically required here — add private IPs only for direct API access.
CORS_ORIGIN="http://localhost:8080,http://localhost:5000"

## ── Hashing ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

## ── Two-Factor Auth ─────────────────────────────────────────────────────────
TOTP_ISSUER=Bach Dang WAF

## ── SSL / ACME ──────────────────────────────────────────────────────────────
SSL_STORE_DIR="/etc/nginx/ssl"
ACME_WEBROOT="/var/www/html/.well-known/acme-challenge"

## ── Nginx log path (production) ─────────────────────────────────────────────
NGINX_LOG_DIR="/var/log/nginx"

## ── SMTP (optional — email alert delivery) ──────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="alerts@example.com"
SMTP_PASS="replace-with-smtp-password"
SMTP_FROM="Bach Dang WAF <alerts@example.com>"

## ── Frontend API base (optional override) ───────────────────────────────────
# Leave empty — the frontend uses relative '/api' paths by default.
# Nginx proxies /api → backend:3001 without any IP hardcoded in the build.
# Only set this when the backend runs on a completely separate host:
# VITE_API_URL=http://10.0.0.5:3001/api
