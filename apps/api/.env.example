## Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/waf_console?schema=public"

## Server
PORT=3001
NODE_ENV=production

## JWT secrets (generate with: openssl rand -hex 48)
JWT_ACCESS_SECRET="replace-with-random-secret"
JWT_REFRESH_SECRET="replace-with-random-secret"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

## Session
SESSION_SECRET="replace-with-random-secret"

## CORS
CORS_ORIGIN="http://localhost:8080,http://localhost:5000"

## Hashing
BCRYPT_ROUNDS=12

## Two-Factor Auth (TOTP)
TOTP_ISSUER=Bach Dang WAF

## SSL / ACME
SSL_STORE_DIR="/etc/nginx/ssl"
ACME_WEBROOT="/var/www/html/.well-known/acme-challenge"

## Nginx logs (production)
NGINX_LOG_DIR="/var/log/nginx"

## SMTP (email alert delivery)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="alerts@example.com"
SMTP_PASS="replace-with-smtp-password"
